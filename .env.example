# ─────────────────────────────────────────────────────────────────────────────
# Kalki Bet — root .env.example
#
# This file is consumed by docker-compose. Copy to `.env` and adjust:
#
#   cp .env.example .env
#
# Every key is also re-exported into each service container via the
# `environment:` block in docker-compose.yml — so editing here is the
# only place you need to touch to retarget the whole stack.
#
# In-container service names (postgres, redis, backend) are used for
# inter-service communication; localhost references are only for what
# the developer types into a browser.
# ─────────────────────────────────────────────────────────────────────────────

# ───── Host port bindings ───────────────────────────────────────────────────
# Set to a free port if anything below already runs on your host (Windows
# users: IIS / Hyper-V / Skype may hold :80; pick :8000 by default).
PROXY_HTTP_PORT=8000
BACKEND_PORT=4000
BET_PORT=3100
AUCTIONS_PORT=3200
AVIATOR_PORT=3000
ADMIN_PORT=5173
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8080
REDIS_COMMANDER_PORT=8081
MAILPIT_HTTP_PORT=8025
MAILPIT_SMTP_PORT=1025

# ───── Postgres ─────────────────────────────────────────────────────────────
# A single Postgres instance serves both the backend (`uniquebid` DB) and
# the bet app (`bet` DB, created by docker/postgres/init/01-create-bet-db.sh
# on first cluster bootstrap).
POSTGRES_USER=kalki
POSTGRES_PASSWORD=kalki
POSTGRES_DB=uniquebid

# ───── Shared secrets ───────────────────────────────────────────────────────
# IMPORTANT: rotate every value below for any deployment beyond a developer
# laptop. The defaults are NOT production-safe — they exist so a fresh
# clone boots without manual key generation.
JWT_SECRET=dev-jwt-secret-change-me-32-chars-min-length
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
NEXTAUTH_SECRET=dev-nextauth-secret-change-me-32-chars-min-length

# BACKEND_JWT_SECRET on the bet side MUST equal JWT_SECRET on the backend
# side for the SSO bridge (auctions/aviator → bet WebView token) to work.
# We default it to the same value for convenience.
BACKEND_JWT_SECRET=${JWT_SECRET}

# Same shared secret protects backend↔bet internal wallet endpoints.
INTERNAL_API_SECRET=dev-internal-secret-change-me

# KYC document encryption — defaults to JWT_SECRET if unset, but you can
# point it elsewhere for crypto-segregation.
# KYC_DOCUMENT_KEY=

# ───── Public service URLs (build-time inlined into client bundles) ────────
# Next.js inlines NEXT_PUBLIC_* and Vite inlines VITE_* AT BUILD TIME, so
# changing these means a `make rebuild`. In dev these point at the proxy
# (recommended) or per-service ports. Mobile/WebView builds usually need
# 10.0.2.2 (Android emulator) or the host LAN IP.
BACKEND_URL=http://localhost:4000
AUCTIONS_URL=http://localhost:3200
AVIATOR_URL=http://localhost:3000
EXCHANGE_URL=http://localhost:3100
ADMIN_URL=http://localhost:5173

# ───── Feature flags ────────────────────────────────────────────────────────
GOOGLE_ENABLED=false
AVIATOR_ROCKET=1

# Bet-specific knobs
SIGNUP_COIN_BONUS=10000
DAILY_REWARD_COINS=500
DISCLAIMER=Demo only — virtual coins, no real-money payouts.

# Dev-only escape hatch: instant wallet top-up without going through
# the payment provider. NEVER enable in production.
ALLOW_INSTANT_TOPUP=true

# Backend role: api (HTTP + WS + cron) or worker (cron-only, no HTTP)
KALKI_ROLE=api

# Comma-separated origin allow-list for the backend CORS layer. Empty
# means "wildcard, no credentials" (loosest). For dev with cookies, set
# this to the proxy + direct-port origins.
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3100,http://localhost:3200,http://localhost:3000,http://localhost:5173

# ───── Optional third-party integrations ────────────────────────────────────
# All blank = service runs in disabled / mock mode (logs instead of sends,
# 503 instead of real payments). Fill in to enable.

# NOWPayments (crypto top-ups, the live real-money path). NOWPAYMENTS_SANDBOX=true
# uses the test network and test funds.
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=
NOWPAYMENTS_SANDBOX=true

# Google OAuth (the "Sign in with Google" button — leave blank to hide).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase Cloud Messaging — path to a service-account JSON MOUNTED INSIDE
# the backend container. Drop the file at docker/secrets/firebase.json
# (gitignored) and uncomment.
# FIREBASE_CREDENTIALS_PATH=/run/secrets/firebase.json

# Sentry (set on bet only — backend logs are still console-based)
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Outbound SMTP — defaults to the bundled Mailpit container so password-
# reset and email-verification flows work in dev without a real provider.
# View captured mail at http://localhost:${MAILPIT_HTTP_PORT}.
SMTP_URL=smtp://mailpit:1025
EMAIL_FROM=Kalki Exchange <noreply@kalki.local>
