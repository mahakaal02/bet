// Prediction-market schema. Demo coins only — no real money flows.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ───── Users & wallet ──────────────────────────────────────────────────────

/// Admin role hierarchy (PR-BET-ADMIN-REDESIGN).
///
/// Two tiers — by design, not five. The product spec wants a single
/// human (the founder / ops lead) to bootstrap operations end-to-end,
/// and grow the team by hiring more operators who share the operator
/// surface. A heavier 5-role matrix (separate finance / compliance /
/// support tiers) would be premature here — every new role boundary
/// is a permission set to maintain, a UI permission gate to audit,
/// and a per-role test surface.
///
///   SUPER_ADMIN  Singleton. Only one row in the database carries this
///                tier. Can create / revoke other admins. Cannot be
///                deleted from the UI — only via direct DB / migration.
///                Seeded from `KALKI_SUPER_ADMIN_EMAIL` env at boot.
///                If multiple rows somehow exist (shouldn't happen via
///                supported paths), the application logic treats the
///                lowest-`createdAt` as authoritative; a partial-unique
///                index on the column enforces the singleton invariant.
///
///   ADMIN        Variable count. Same operational permissions as the
///                super admin EXCEPT can't manage other admins. New
///                admins are invited by the super admin from the
///                Roles surface (`/admin/roles`).
///
/// The existing `User.isAdmin` boolean is kept for backwards compat
/// during the rollout — `getAuthedUser()` returns true for it on any
/// non-null `adminRole`. New code should read `adminRole`; legacy
/// callers continue to work.
enum AdminRole {
  SUPER_ADMIN
  ADMIN
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  username      String   @unique
  passwordHash  String?
  image         String?
  /// Legacy admin flag. Kept for back-compat with existing code paths
  /// that read `isAdmin`. The new `adminRole` column is authoritative;
  /// `isAdmin` is derived (`adminRole != null`) and the migration
  /// backfills it accordingly. New auth checks should prefer
  /// `adminRole != null` directly, but `isAdmin` continues to work.
  isAdmin       Boolean  @default(false)
  /// Tier in the admin hierarchy. NULL = regular user.
  /// See [AdminRole] for semantics. Backfilled from `isAdmin` so any
  /// row that was admin pre-migration becomes an ADMIN; the
  /// super-admin seed promotes one row to SUPER_ADMIN at deploy time.
  adminRole     AdminRole?
  banned        Boolean  @default(false)
  suspendedUntil DateTime? @db.Timestamptz(6)
  // Cached XP / level / streak so leaderboards & profile don't recompute.
  xp            Int      @default(0)
  level         Int      @default(1)
  streak        Int      @default(0)
  lastClaimAt   DateTime? @db.Timestamptz(6)
  referralCode  String?  @unique
  referredById  String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  wallet        Wallet?
  positions     Position[]
  trades        Trade[]
  txns          Transaction[]
  rewards       Reward[]
  watchlist     Watchlist[]
  notifications Notification[]
  comments      Comment[]
  adminLogs     AdminLog[]
  accounts      Account[]
  sessions      Session[]
  marketsCreated Market[] @relation("MarketCreator")
  achievements   UserAchievement[]
  emailVerifications EmailVerification[]
  passwordResets PasswordReset[]
  orders         Order[]
  reportsFiled   Report[] @relation("Reporter")
  reportsResolved Report[] @relation("Resolver")
  cryptoPayments  CryptoPaymentOrder[]
  withdrawals     WithdrawalRequest[]
  withdrawalsDecided WithdrawalRequest[] @relation("WithdrawalDecider")
  emailVerified Boolean   @default(false)
  emailVerifiedAt DateTime? @db.Timestamptz(6)
  referrer      User?     @relation("Referrals", fields: [referredById], references: [id])
  referred      User[]    @relation("Referrals")

  @@index([username])
  @@index([xp(sort: Desc)])
}

// NextAuth required tables (only present so Google OAuth works out of the
// box; Credentials sessions don't write to these).
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime @db.Timestamptz(6)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime @db.Timestamptz(6)

  @@unique([identifier, token])
}

// Coins are stored on Wallet rather than inline on User so a future
// multi-currency expansion (e.g. seasonal coins) just adds rows here.
model Wallet {
  id          String   @id @default(cuid())
  userId      String   @unique
  balance     Int      @default(0)   // demo coins
  lockedInOrders Int   @default(0)   // reserved by open orders (future-proof)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ───── Markets ─────────────────────────────────────────────────────────────

enum MarketCategory {
  POLITICS
  SPORTS
  CRYPTO
  TECH
  ENTERTAINMENT
}

enum MarketStatus {
  OPEN
  CLOSED
  RESOLVED
  CANCELLED
}

enum Outcome {
  YES
  NO
}

model Market {
  id          String         @id @default(cuid())
  slug        String         @unique
  title       String
  description String
  bannerUrl   String?
  category    MarketCategory
  resolutionSource String?
  endsAt      DateTime @db.Timestamptz(6)
  status      MarketStatus   @default(OPEN)
  resolvedAs  Outcome?
  resolvedAt  DateTime? @db.Timestamptz(6)
  resolutionNote String?
  featured    Boolean        @default(false)

  // Constant-product AMM reserves. Price of YES = noShares / (yesShares + noShares).
  // Seeded by the admin (default 1000/1000 → 50%/50%). Updated atomically on
  // every trade.
  yesShares   Float          @default(1000)
  noShares    Float          @default(1000)
  // Lifetime volume of coins traded across both sides (for trending sort).
  volumeCoins Int            @default(0)
  // Trending score — exponentially-decayed volume, recomputed by the
  // scheduler. Higher = more trending.
  trendingScore Float        @default(0)

  createdById String?
  createdAt   DateTime       @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime       @updatedAt @db.Timestamptz(6)

  createdBy   User?          @relation("MarketCreator", fields: [createdById], references: [id])

  trades      Trade[]
  positions   Position[]
  pricePoints PricePoint[]
  comments    Comment[]
  watchlist   Watchlist[]
  orders      Order[]
  orderMatches OrderMatch[]
  translations MarketTranslation[]

  // ───── Grouped markets (additive — see MarketGroup below) ─────────────────
  // Nullable: a market with groupId = null is a standalone market and trades,
  // prices and settles EXACTLY as before. Grouping is metadata on top; nothing
  // in the trading/settlement hot paths reads these columns.
  groupId        String?
  groupSortOrder Int?
  group          MarketGroup? @relation(fields: [groupId], references: [id], onDelete: SetNull)

  @@index([status, endsAt])
  @@index([category, status])
  @@index([trendingScore(sort: Desc)])
  @@index([featured])
  @@index([groupId])
}

// ───── Grouped markets (Kalshi-style events) ──────────────────────────────
//
// A MarketGroup ("event") ties several existing binary markets together for
// display, ranking and (optionally) coordinated resolution — e.g. "Who will
// win the election?" with one child market per candidate. PURELY ADDITIVE:
// each child is still an ordinary YES/NO Market that trades and settles like a
// standalone market; the group is a presentation + orchestration layer on top.
// With zero MarketGroup rows the platform behaves identically to before.
enum MarketGroupType {
  EXCLUSIVE   // mutually-exclusive: exactly one child resolves YES, the rest NO; display normalized to 100%
  INDEPENDENT // independent questions sharing an event shell; no normalization, no coupled resolution
}

enum MarketGroupStatus {
  OPEN
  CLOSED
  RESOLVED
  CANCELLED
}

model MarketGroup {
  id          String            @id @default(cuid())
  slug        String            @unique
  title       String
  description String?
  category    MarketCategory
  type        MarketGroupType   @default(EXCLUSIVE)
  status      MarketGroupStatus @default(OPEN)
  featured    Boolean           @default(false)
  sortOrder   Int               @default(0)

  // Group-level resolution audit (Phase 2). Payouts still run per child via the
  // existing per-market settlement; these columns only record the group
  // decision. resolvedWinnerMarketId is the child that resolved YES.
  resolvedWinnerMarketId String?
  resolvedAt             DateTime? @db.Timestamptz(6)
  resolutionNote         String?

  // Admin who created the group — plain column, no relation (mirrors
  // Settlement.executedById) so the User model is left untouched.
  createdById String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  markets Market[]

  @@index([status, sortOrder])
  @@index([category, status])
  @@index([featured])
}

// ───── Localized market content (PR-BET-I18N) ─────────────────────────────
//
// Sidecar table holding per-locale translations of Market.title and
// Market.description. Design choices:
//
//   • One row per (marketId, locale) — only inserted when a translation
//     actually exists. A market with no rows here falls back to the
//     canonical Market.title/description (authoring language). No row
//     duplication for untranslated markets; the table stays small.
//   • title/description columns are nullable so a translator can fill
//     only one without producing an empty placeholder for the other.
//     The display helper (`lib/i18n/market-content.ts::getLocalizedMarket`)
//     handles per-field fallback: prefers the translation, falls back
//     to canonical when the translation field is null.
//   • Cascade-delete on Market — orphan translations are useless and
//     would prevent admin deletion otherwise.
//   • Unique (marketId, locale) ensures we never accumulate duplicate
//     rows for the same (market, locale) pair under concurrent admin
//     edits.
//
// Lifecycle: admin UI (out-of-scope follow-up) writes rows here. The
// reader-side fallback is already in place via the helper, so adding
// translations is purely additive — no client deploy needed.
model MarketTranslation {
  id          String   @id @default(cuid())
  marketId    String
  locale      String   // "en" | "pt" | "es" | "fr" — see lib/i18n/config.ts
  title       String?
  description String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)
  // Admin operator who created/last-edited this translation. Optional —
  // machine-translated rows have no human author.
  authorId    String?

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([marketId, locale])
  @@index([locale])
}

// Snapshot of mid price after each trade — used to draw the price chart on
// the market detail page. Trimmed by the scheduler when older than 30 days.
model PricePoint {
  id        String   @id @default(cuid())
  marketId  String
  yesPrice  Float    // 0..1
  noPrice   Float    // 0..1
  recordedAt DateTime @default(now()) @db.Timestamptz(6)

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@index([marketId, recordedAt])
}

// ───── Trading ─────────────────────────────────────────────────────────────

model Trade {
  id        String   @id @default(cuid())
  marketId  String
  userId    String
  outcome   Outcome
  // How many "shares" the user bought. Each YES share pays 1 coin if YES
  // resolves; each NO share pays 1 coin if NO resolves.
  shares    Float
  // Coins flowing on the user side, signed: +ve on BUY (debit from wallet),
  // -ve on SELL (credit to wallet). This is the NET amount after the
  // platform fee — see `feeCoins` for the fee that was skimmed.
  cost      Int
  // Platform commission collected on this fill (2% of notional, 0 on
  // pre-commission historical rows). Always positive. Lives separately
  // from `cost` so analytics can sum revenue without sign-juggling.
  feeCoins  Int      @default(0)
  // Realised average price per share, for receipts and analytics.
  pricePerShare Float
  // Snapshots of market reserves AFTER this trade. Lets the chart be
  // reconstructed deterministically from Trade alone.
  yesSharesAfter Float
  noSharesAfter  Float
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt])
  @@index([userId, createdAt])
}

// Singleton row (id = "singleton"). Cached running counters for platform
// revenue so the admin dashboard reads O(1) instead of aggregating the
// Transaction ledger. Updated inside the same DB transaction as the fee
// movement — Transaction rows remain the audit-of-record; this row is a
// derived view that must agree with `SUM(delta) WHERE kind LIKE 'commission_%'`.
model PlatformRevenue {
  id                   String   @id @default("singleton")
  // Buy + sell commissions collected on every fill (book + AMM legs).
  totalTradingFees     Int      @default(0)
  // 5% rake on net profit at market resolution. Principal is never docked.
  totalSettlementFees  Int      @default(0)
  // Convenience sum, maintained alongside the two above to avoid a runtime
  // add on every dashboard render. Invariant:
  //   totalPlatformRevenue == totalTradingFees + totalSettlementFees.
  totalPlatformRevenue Int      @default(0)
  updatedAt            DateTime @updatedAt @db.Timestamptz(6)
}

// One row per (user, market, outcome). Updated atomically with each trade.
// `locked` is the count of shares currently posted as SELL orders on the
// orderbook; `shares - locked` is what's truly available for new SELLs.
model Position {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  outcome   Outcome
  shares    Float    @default(0)
  locked    Float    @default(0)
  costBasis Int      @default(0)  // total coins spent on this leg
  realizedPnl Int    @default(0)  // set on resolution
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId, outcome])
  @@index([userId])
  @@index([marketId])
}

// ───── Orderbook ───────────────────────────────────────────────────────────

enum OrderSide {
  BUY
  SELL
}

enum OrderStatus {
  OPEN
  PARTIAL
  FILLED
  CANCELLED
}

/// A limit order on a market's binary outcome book. BUYs reserve coins
/// (`remaining * limitPrice`) at submit; SELLs reserve shares from the
/// matching Position. Reservations release on fill or cancel.
///
/// Matching is price-time priority within (marketId, outcome, side). A new
/// BUY crosses against SELLs sorted by ascending limitPrice; a new SELL
/// crosses against BUYs sorted by descending limitPrice. Taker pays the
/// resting maker's price (price improvement passes back to the taker).
model Order {
  id          String      @id @default(cuid())
  userId      String
  marketId    String
  outcome     Outcome
  side        OrderSide
  limitPrice  Float       // 0..1
  shares      Float       // original size
  remaining   Float       // unfilled
  filledShares Float      @default(0)
  filledCost  Int         @default(0)
  status      OrderStatus @default(OPEN)
  createdAt   DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(6)
  cancelledAt DateTime? @db.Timestamptz(6)
  filledAt    DateTime? @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  takerMatches OrderMatch[] @relation("TakerMatches")
  makerMatches OrderMatch[] @relation("MakerMatches")

  @@index([marketId, outcome, side, status])
  @@index([userId, status, createdAt])
  @@index([marketId, outcome, side, limitPrice])
}

/// Each fill produces one OrderMatch (two-sided audit) and one Trade
/// (single-sided audit, kept for the existing portfolio views). Splitting
/// the two keeps settlement bookkeeping unambiguous.
model OrderMatch {
  id           String    @id @default(cuid())
  marketId     String
  outcome      Outcome
  shares       Float
  price        Float     // 0..1
  takerOrderId String
  makerOrderId String
  takerUserId  String
  makerUserId  String
  takerSide    OrderSide
  createdAt    DateTime  @default(now()) @db.Timestamptz(6)

  market     Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  takerOrder Order  @relation("TakerMatches", fields: [takerOrderId], references: [id], onDelete: Cascade)
  makerOrder Order  @relation("MakerMatches", fields: [makerOrderId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt(sort: Desc)])
}

// Coin movement audit. Idempotent on (kind, reference) for guarded operations
// like daily-claim and resolution payouts.
model Transaction {
  id        String   @id @default(cuid())
  userId    String
  delta     Int      // positive = credit, negative = debit
  kind      String   // "signup_bonus" | "daily_claim" | "trade_buy" | "resolution_payout" | "admin_grant" | "referral_bonus"
  reference String?
  metadata  Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([kind, reference], name: "uniq_kind_reference")
  @@index([userId, createdAt(sort: Desc)])
}

// ───── Rewards / gamification ──────────────────────────────────────────────

model Reward {
  id        String   @id @default(cuid())
  userId    String
  kind      String   // "daily" | "streak_3" | "first_trade" | "ten_trades" | "referral"
  coins     Int
  claimedAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, claimedAt(sort: Desc)])
}

// Cached daily leaderboard. Refreshed by the scheduler — querying live is
// fine for now, but having this row makes the landing-page widget cheap.
model LeaderboardEntry {
  id        String   @id @default(cuid())
  userId    String   @unique
  username  String
  xp        Int
  level     Int
  netPnl    Int      @default(0)
  computedAt DateTime @default(now()) @db.Timestamptz(6)

  @@index([xp(sort: Desc)])
}

// ───── Social ──────────────────────────────────────────────────────────────

model Watchlist {
  id        String   @id @default(cuid())
  userId    String
  marketId  String
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)

  @@unique([userId, marketId])
}

model Comment {
  id        String   @id @default(cuid())
  marketId  String
  userId    String
  body      String   @db.VarChar(500)
  hidden    Boolean  @default(false)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  market Market @relation(fields: [marketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([marketId, createdAt(sort: Desc)])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  href      String?
  readAt    DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// ───── Admin ───────────────────────────────────────────────────────────────

// ───── Achievements ────────────────────────────────────────────────────────

/// Catalog of badges. Static rows seeded by `prisma/seed.ts`; the runtime
/// engine in `lib/achievements.ts` references them by their stable `code`.
model Achievement {
  id          String   @id @default(cuid())
  code        String   @unique  // "first_trade" | "ten_trades" | …
  title       String
  description String
  icon        String   // emoji or lucide icon name
  rewardCoins Int      @default(0)
  rewardXp    Int      @default(0)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  unlocks UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now()) @db.Timestamptz(6)

  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement  Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt(sort: Desc)])
}

// Email verification token. Hashed in the DB; raw token only exists in the
// emailed link. 24-hour TTL enforced at use time.
model EmailVerification {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

// Password-reset token. Same shape as EmailVerification but kept separate so
// rotating reset tokens doesn't invalidate pending verifications.
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  codeHash  String
  expiresAt DateTime @db.Timestamptz(6)
  consumedAt DateTime? @db.Timestamptz(6)
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
}

/// User-submitted report on a piece of content. Currently only `COMMENT`
/// is wired through the UI; the polymorphic `targetType + targetId` lets us
/// flag markets / users without another model later.
model Report {
  id          String       @id @default(cuid())
  reporterId  String
  targetType  ReportTarget
  targetId    String
  reason      String       @db.VarChar(280)
  status      ReportStatus @default(PENDING)
  resolverId  String?
  resolverNote String?     @db.VarChar(280)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  resolvedAt  DateTime?    @db.Timestamptz(6)

  reporter User  @relation("Reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver User? @relation("Resolver", fields: [resolverId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([targetType, targetId])
  // One pending report per (reporter, target) — second click is a no-op
  // rather than spamming the queue.
  @@unique([reporterId, targetType, targetId, status])
}

enum ReportTarget {
  COMMENT
  MARKET
}

enum ReportStatus {
  PENDING
  RESOLVED
  DISMISSED
}

model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String   // "market.create" | "market.resolve" | "user.ban" | "user.grant" | ...
  targetId  String?
  metadata  Json?
  createdAt DateTime @default(now()) @db.Timestamptz(6)

  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([createdAt(sort: Desc)])
}

// ───── Withdrawals ─────────────────────────────────────────────────────────

enum WithdrawalStatus {
  PENDING     // user submitted, admin not yet reviewed
  APPROVED    // admin approved, payout in flight
  PAID        // payout completed (payout reference id captured)
  REJECTED    // admin rejected, coins refunded
  CANCELLED   // user cancelled before admin review
}

enum PayoutMethod {
  UPI
  BANK
  CRYPTO
}

/// User-initiated withdrawal of coins → INR. Locks the coins on creation
/// (debits Wallet.balance, the audit row carries the negative delta);
/// REJECTED / CANCELLED refund them via an inverse credit. APPROVED is
/// terminal once the admin clicks — actual payout is processed
/// externally and the reference recorded.
model WithdrawalRequest {
  id            String   @id @default(cuid())
  userId        String
  amountCoins   Int      // = INR at 1:1
  payoutMethod  PayoutMethod
  /// JSON shape depends on method: { upiId } | { accountNumber, ifsc, name }.
  payoutDetails Json
  status        WithdrawalStatus @default(PENDING)
  decisionNote  String?
  decidedById   String?
  decidedAt     DateTime? @db.Timestamptz(6)
  paidReference String?  // payout reference id once the transfer completes
  paidAt        DateTime? @db.Timestamptz(6)
  /// IP + user-agent at submission time — useful for the admin audit page
  /// (multi-device patterns, geo anomalies).
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime @default(now()) @db.Timestamptz(6)

  user      User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  decidedBy User? @relation("WithdrawalDecider", fields: [decidedById], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
}

// ───── Admin operations (PR-BET-ADMIN-REDESIGN) ────────────────────────────
//
// Six small models that back the new admin console modules. Every one
// is additive — no existing column changed, no constraint added that
// could break a running query — so the migration can roll forward and
// back without coordination.
//
// Design philosophy: when in doubt, defer detail to JSON. The columns
// here are the ones we'll filter / index on; everything else lives in
// the `metadata` / `payload` JSON blob. Schema churn during the
// admin-console buildout is much cheaper that way.

/// Admin invite (RBAC).
///
/// Super-admin-only flow. Super admin enters an email + chosen username
/// + role on `/admin/roles`, server inserts a row here with a random
/// `token`. The invitee receives a one-time link they redeem to
/// finish account creation (set password). On redemption, the invite
/// row is consumed (`acceptedAt` set) and the user's `adminRole` is
/// promoted.
///
/// `expiresAt` defaults to 7d after `createdAt`; expired invites are
/// rejected at redemption and surfaced as "expired" in the UI so the
/// super admin can re-issue.
model AdminInvite {
  id          String   @id @default(cuid())
  email       String
  username    String
  role        AdminRole @default(ADMIN)
  token       String   @unique
  invitedById String
  expiresAt   DateTime @db.Timestamptz(6)
  acceptedAt  DateTime? @db.Timestamptz(6)
  acceptedById String?
  revokedAt   DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([email])
  @@index([invitedById])
}

/// Generic key-value setting with audit trail (system settings page).
///
/// Strongly typed via the `type` column so the UI can render the right
/// editor (toggle vs number-input vs JSON textarea). `value` is JSON
/// to avoid table churn when new setting kinds appear; the loader
/// validates against an in-code catalogue.
model AdminSetting {
  key         String   @id
  value       Json
  type        String   // "string" | "number" | "boolean" | "json"
  category    String   // "fees" | "limits" | "kyc" | "oracle" | ...
  sensitive   Boolean  @default(false)
  description String?
  updatedById String?
  updatedAt   DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@index([category])
}

/// Heuristic fraud signal (fraud & risk page).
///
/// Inserted by the fraud-detection worker (separate PR) or by an
/// operator manually flagging. `evidence` carries kind-specific
/// supporting data so the triage UI can render rich proof without a
/// schema change per detector.
model FraudSignal {
  id          String   @id @default(cuid())
  kind        String   // "wash_trade" | "multi_account" | "spike" | "bot_rhythm"
  severity    String   // "low" | "medium" | "high" | "critical"
  userId      String?
  marketId    String?
  summary     String   // one-line description for the queue
  evidence    Json     @default("{}")
  status      String   @default("OPEN") // "OPEN" | "REVIEWED" | "DISMISSED" | "ESCALATED"
  reviewedById String?
  reviewedAt  DateTime? @db.Timestamptz(6)
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([status, createdAt(sort: Desc)])
  @@index([userId])
  @@index([marketId])
}

/// KYC submission (bet-side).
///
/// Mirrors the auctions KycSubmission shape — same status lifecycle
/// and rejection-code enum — so a future consolidated KYC service can
/// merge both into one table without UI churn. Document refs are
/// opaque S3 keys; the actual bytes never live in this DB.
model KycSubmission {
  id          String   @id @default(cuid())
  userId      String   @unique
  // Document refs as JSON: { pan: "s3://...", aadhaar: "s3://...", selfie: "s3://..." }
  documents   Json
  status      String   @default("PENDING") // PENDING | APPROVED | REJECTED | REQUEST_MORE
  rejectionCode String?
  reviewedById String?
  reviewedAt  DateTime? @db.Timestamptz(6)
  notes       String?
  // Optional face-match score from the auto-OCR pipeline (0..1).
  faceMatchScore Float?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @db.Timestamptz(6)

  @@index([status, createdAt(sort: Desc)])
}

/// Settlement record (payout management).
///
/// One row per market resolution. The existing in-line
/// `/api/admin/markets/[id]/resolve` route can populate this on
/// success without changing its return shape — the row exists for
/// observability + retry orchestration, not as a state machine.
/// `attempts` lets a follow-up worker re-credit users whose wallet
/// update raced and lost.
model Settlement {
  id             String   @id @default(cuid())
  marketId       String   @unique
  outcome        String   // YES | NO | CANCELLED
  totalPayout    Int      // coins
  totalFees      Int      // coins
  winnerCount    Int
  loserCount     Int
  status         String   @default("EXECUTED") // PENDING | EXECUTED | FAILED
  executedById   String
  attempts       Int      @default(1)
  lastError      String?
  createdAt      DateTime @default(now()) @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @db.Timestamptz(6)

  @@index([status, createdAt(sort: Desc)])
}

/// API call log (API & webhook monitoring page).
///
/// Lightweight — every API route inserts one row via a Next.js
/// middleware. 30-day retention via a scheduled cleanup, so the table
/// stays small enough for ad-hoc queries. Indexed by status code so
/// "show me all 5xx in the last hour" is fast.
model ApiLog {
  id          BigInt   @id @default(autoincrement())
  method      String
  path        String
  status      Int
  durationMs  Int
  userId      String?
  ip          String?
  userAgent   String?
  errorCode   String?
  createdAt   DateTime @default(now()) @db.Timestamptz(6)

  @@index([createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@index([path, createdAt(sort: Desc)])
}

// ───── NOWPayments crypto top-ups (PR-BET-NOWPAYMENTS) ─────────────────────
//
// The platform's sole payment path (Razorpay was removed). Crypto's
// shape: hosted invoices instead of orders, IPN callbacks instead of
// client-side signature verification, and a status machine with
// "confirming" + "partially_paid" states.
//
// A `Transaction(kind='deposit', reference='nowpayments:<paymentId>')`
// row is written on IPN-finished, giving idempotency so duplicate IPN
// deliveries are harmless.

model CryptoPaymentOrder {
  id               String   @id @default(cuid())
  userId           String
  packId           String   // matches lib/coin-packs.ts
  amountInr        Int      // INR-equivalent at order time (for receipts)
  coins            Int      // coins to credit on finished
  // NOWPayments references. `invoiceId` is set immediately on create;
  // `paymentId` only after the user picks a coin in the hosted UI.
  invoiceId        String?  @unique // np invoice id (numeric or string)
  paymentId        String?  @unique // np payment id once the user commits
  payCurrency      String?  // "btc" / "eth" / "usdttrc20" / ...
  payAmount        String?  // crypto units (string to avoid Float drift)
  payAddress       String?  // deposit address shown to the user
  hostedInvoiceUrl String?  // https://nowpayments.io/payment/?iid=...
  // Status mirrors the NOWPayments payment_status field plus our own
  // PENDING bookend. See lib/nowpayments.ts for the state machine.
  status           String   @default("PENDING")
  // Last IPN payload — useful for the admin payouts view when a
  // payment gets stuck in confirming / partially_paid and ops needs
  // to investigate.
  rawWebhook       Json?
  failureReason    String?
  createdAt        DateTime @default(now()) @db.Timestamptz(6)
  capturedAt       DateTime? @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
}
