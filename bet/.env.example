# Bet — prediction market app. Copy to .env and fill in.

# Postgres. Reuse the host Postgres from the rest of the monorepo, but use a
# separate database so the Bet schema doesn't collide with UniqueBid auctions.
DATABASE_URL="postgresql://postgres:password@localhost:5432/bet?schema=public"

# NextAuth requires a secret. Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-please-change-me-please-change-me"
NEXTAUTH_URL="http://localhost:3100"

# Google OAuth (optional — leave blank to disable the button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# How many demo coins each new user receives.
SIGNUP_COIN_BONUS="10000"

# Daily-faucet reward (coins per claim).
DAILY_REWARD_COINS="500"

# DEV-ONLY escape hatch. Setting this to "true" lets /api/wallet/topup
# credit a wallet immediately without a real payment. Effectively a
# free-money button — leave UNSET in production. The NOWPayments crypto
# flow (below) is the only acceptable production path.
ALLOW_INSTANT_TOPUP=""

# Shared secret for server-to-server wallet calls (auctions backend +
# Aviator → Kalki Exchange wallet). Generate with: openssl rand -base64 32.
# Leave unset to disable the /api/internal/wallet endpoints entirely.
INTERNAL_API_SECRET=""

# SSO bridge from the auctions backend. When the Android app opens Bet in a
# WebView it appends `?token=<backendJWT>` to the URL; the `backend-jwt`
# NextAuth provider verifies that HMAC against this secret and signs the
# user in transparently (or provisions a matching Bet account on first
# visit). MUST match the auctions backend's `JWT_SECRET` exactly — copy
# the value verbatim. Leave unset to disable the bridge.
BACKEND_JWT_SECRET=""

# ───── Optional production infra ─────────────────────────────────────────────

# Redis (optional). Set REDIS_URL to flip the rate limiter from in-memory to
# Redis token-buckets and the pub/sub backend from EventEmitter to Redis.
# Required once the app runs on multiple instances behind a load balancer.
# REDIS_URL="redis://localhost:6379"

# Sentry error reporting (optional). Set SENTRY_DSN AND run `npm i @sentry/node`
# to opt in. Without these, logger.error falls back to console / process logs.
# SENTRY_DSN=""
# SENTRY_TRACES_SAMPLE_RATE="0.1"

# SMTP outbound mail (optional). Set SMTP_URL AND run `npm i nodemailer` to
# send verification + password-reset emails. Without it, lib/email.ts logs
# the link to the dev console so you can copy/paste it during local dev.
# SMTP_URL=""
# EMAIL_FROM="Kalki Exchange <noreply@kalki.local>"

# ───── NOWPayments (crypto top-ups) ────────────────────────────────────────
# PR-BET-NOWPAYMENTS. Primary payment path now. Top-ups go through a
# NOWPayments hosted invoice → user pays in BTC / ETH / USDT / ... →
# IPN callback verifies HMAC-SHA512 and credits the wallet.
#
# Get the API key + IPN secret from NOWPayments dashboard → Settings
# → Payments API. The IPN URL to register there is:
#   https://<your-host>/api/webhooks/nowpayments
#
# Sandbox mode routes to api-sandbox.nowpayments.io and uses test
# funds — flip to "false" when ready to take real payments.
NOWPAYMENTS_API_KEY=""
NOWPAYMENTS_IPN_SECRET=""
NOWPAYMENTS_SANDBOX="true"
