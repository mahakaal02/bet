<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!--
      Network security policy (PR-ANDROID-SECURITY).

      `usesCleartextTraffic` was previously `true`, opting the whole
      app into plain-HTTP. That's a hard fail in a production app
      holding bearer tokens and Razorpay credentials — a coffee-shop
      MITM could see and replay every request.

      Now we delegate the policy to `network_security_config.xml`:
        - main:  cleartext OFF for every domain.
        - debug: cleartext ON only for the emulator alias 10.0.2.2 +
                 localhost (so `./gradlew installDebug` keeps working
                 against a local backend).

      `android:allowBackup="false"` was already set; we keep it.
      Disabling backup keeps EncryptedSharedPreferences out of
      adb-backup tarballs (the master key lives in the Android
      Keystore but the encrypted prefs file would otherwise be
      backed up + restorable on a rooted attacker's device).
    -->
    <!--
      `android:hardwareAccelerated="true"` is the platform default for
      targetSdk ≥ 14, but some OEM ROMs (Vivo, Oppo, certain custom
      Samsung skins) silently disable it for APKs signed with non-
      Play-Store keystores — and our release build is signed with the
      debug keystore (`app/build.gradle.kts` release signingConfig).
      Declaring it explicitly here forces it on regardless of vendor
      defaults, which keeps the WebView scroll path running on the GPU.
      Without it, scrolling a long leaderboard inside the WebView spins
      up the software rasteriser and the render process is killed by
      the system within minutes (no `onRenderProcessGone` override at
      the time of writing → parent process dies too → user is bounced
      to Splash, where the next /auth/me hit can compound into a
      "spontaneous logout" report). PR-ANDROID-STAY-LOGGED-IN.

      `largeHeap="true"` triples the per-process heap ceiling on
      devices that respect it. The leaderboard fetch happens entirely
      inside the WebView, which on first paint can allocate dozens of
      Bitmap-backed render-process buffers; cheap insurance against
      OOM kills on mid-range Android.
    -->
    <application
        android:name=".UniqueBidApp"
        android:allowBackup="false"
        android:hardwareAccelerated="true"
        android:largeHeap="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.UniqueBid">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.UniqueBid"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

    </application>

</manifest>
