<?xml version="1.0" encoding="utf-8"?>
<!--
  Debug-only network-security policy (PR-ANDROID-SECURITY).

  Build variant `debug` swaps the main config (cleartext blocked) for
  this one, which carves a single exception: the Android emulator's
  loopback alias `10.0.2.2` (and `localhost` for physical devices on
  the same Wi-Fi via adb reverse). All other domains stay TLS-only.

  The emulator alias is a well-known Android development pattern —
  `10.0.2.2` is the host machine's loopback as seen from inside the
  Android emulator VM. Cleartext is fine here because the traffic
  never leaves the host machine.

  This file is NOT shipped to the Play Store — release builds use
  app/src/main/res/xml/network_security_config.xml which has cleartext
  globally OFF.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Emulator + adb-reverse cleartext exception. -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>
