generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String?  @unique
  username      String   @unique
  passwordHash  String
  emailVerified Boolean  @default(false)
  isAdmin       Boolean  @default(false)
  // WhatsApp-based identity (alternative to email signup).
  whatsappPhone String?  @unique
  phoneVerified Boolean  @default(false)
  /// Canonical wallet identity on Bet (Kalki Exchange). Populated lazily on
  /// the first wallet operation via POST /api/internal/users/ensure on the
  /// Bet host. Coin balances + wallet ledger live entirely on Bet, keyed by
  /// this column — this backend keeps no local balance state of its own.
  betUserId     String?  @unique
  createdAt     DateTime @default(now())

  // Display profile (F-USER-5).
  displayName   String?
  avatarKey     String?           // S3 key in the public avatars bucket
  // Legal name for KYC name-match (F-USER-13). Encrypted at rest at the
  // application layer; column type is bytea via the encryption wrapper.
  legalName     String?
  // Referral identity (F-USER-4). One per user, immutable once set.
  referralCode  String?  @unique
  // Ban support (F-ADMIN-2).
  bannedAt      DateTime?
  bannedReason  String?
  bannedBy      String?
  // Session-invalidation anchor: any JWT with iat < passwordChangedAt
  // is rejected. Used by password-reset (F-USER-10) and email-change
  // (F-USER-11) to force re-login on every device.
  passwordChangedAt DateTime?

  bids          Bid[]
  wins          Auction[] @relation("AuctionWinner")
  devices       DeviceToken[]
  coinTxns      CoinTransaction[]
  aviatorBets   AviatorBet[]
  aviatorMsgs   AviatorChatMessage[]

  // ─── Foundation relations ─────────────────────────────────────────
  roles                UserRole[]
  adminAuditLogs       AdminAuditLog[]               @relation("AuditActor")
  notifications        Notification[]
  notificationPreference NotificationPreference?
  watchlist            Watchlist[]
  shippingAddresses    ShippingAddress[]
  referralsGiven       ReferralClaim[]               @relation("ReferralReferrer")
  referralReceived     ReferralClaim?                @relation("ReferralReferee")
  kyc                  KycVerification?
  rgProfile            ResponsibleGamblingProfile?
  rgEvents             ResponsibleGamblingEvent[]
  tickets              SupportTicket[]
  assignedTickets      SupportTicket[]               @relation("AssignedTickets")
  ticketMessages       SupportMessage[]
  profileHistory       UserProfileHistory[]
  dailyLogin           DailyLogin?
  dailyLoginClaims     DailyLoginClaim[]
  passwordResets       PasswordReset[]
  twoFactor            TwoFactorAuth?
  trustedDevices       TrustedDevice[]
  emailChanges         EmailChangeRequest[]
  accountDeletion      AccountDeletion?
  dataExports          DataExportRequest[]
  userExports          UserExport[]
  impersonationsAsAdmin ImpersonationLog[]           @relation("ImpersonatorAdmin")
  impersonationsOfMe    ImpersonationLog[]           @relation("ImpersonatedUser")
}

model DeviceToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  platform  String   // "android" | "ios"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Auction {
  id          String         @id @default(uuid())
  title       String
  description String
  imageUrls   String[]       @default([])
  retailPrice Decimal        @db.Decimal(12, 2)
  coinsPerBid Int
  // When the auction transitions from UPCOMING → LIVE. Auctions whose
  // startsAt is in the past are LIVE immediately; the scheduler promotes
  // others when their startsAt arrives.
  startsAt    DateTime?
  endsAt      DateTime
  status      AuctionStatus  @default(UPCOMING)
  winnerId    String?
  winnerAmount Decimal?      @db.Decimal(12, 2)
  closedAt    DateTime?
  createdAt   DateTime       @default(now())

  /// Admin override controls. NORMAL is the default — the auction settles
  /// by the natural lowest-unique-bid rule. NO_WINNER and FIXED_WINNER are
  /// kill-switch / rigging modes used for marketing demos or "house always
  /// wins" promotions; see `bidding-engine.ts::classifyPlacedAmount` and
  /// `bids.service.ts::placeBid` for the runtime behaviour.
  manipulationMode    AuctionManipulationMode @default(NORMAL)
  /// Set when `manipulationMode = FIXED_WINNER`. The first bid landing at
  /// exactly this amount is treated as the winner; other bidders at the
  /// same amount see "Duplicate / Colliding". Null otherwise.
  fixedWinningAmount  Decimal? @db.Decimal(12, 2)

  winner      User?          @relation("AuctionWinner", fields: [winnerId], references: [id])
  bids        Bid[]
  watchlist   Watchlist[]
  // PR-ORDER-1: the auction → order back-relation. The Foundation PR
  // left this commented because the Order model lived alone; ORDER-1
  // wires it through. `?` keeps existing prod auctions (no order yet)
  // valid until the lifecycle migration writes their rows.
  order       Order?         @relation("AuctionOrder")

  @@index([status, endsAt])
  @@index([status, startsAt])
}

enum AuctionStatus {
  UPCOMING
  LIVE
  ENDED
}

/// Admin manipulation modes for an auction:
///   - NORMAL          — natural lowest-unique-bid rule. Default.
///   - NO_WINNER       — kill-switch. Whenever a bid would classify as
///                       "Lowest & Unique", the ringmaster sentinel user
///                       auto-places a duplicate to nullify the win.
///   - FIXED_WINNER    — admin pre-picks the winning amount. First bidder
///                       at `fixedWinningAmount` wins; others at the same
///                       amount see "Duplicate / Colliding".
enum AuctionManipulationMode {
  NORMAL
  NO_WINNER
  FIXED_WINNER
}

model Bid {
  id        String   @id @default(uuid())
  auctionId String
  userId    String
  amount    Decimal  @db.Decimal(12, 2)
  createdAt DateTime @default(now())

  auction Auction @relation(fields: [auctionId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  // Fast lookup for the bidding engine: classify a candidate against an
  // auction's bids by amount.
  @@index([auctionId, amount])
  @@index([auctionId, userId])
}

// Singleton row (id = "default"). Admin-controlled coin economy.
model CoinSettings {
  id                 String   @id @default("default")
  inrPerCoin         Decimal  @db.Decimal(10, 2) @default(5.00)
  defaultCoinsPerBid Int      @default(1)
  updatedAt          DateTime @updatedAt
}

// Admin-defined SKUs users can purchase. Razorpay orders reference these by id.
model CoinPack {
  id        String   @id @default(uuid())
  coins     Int
  priceInr  Decimal  @db.Decimal(10, 2)
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  orders    PaymentOrder[]
}

// Local audit row for coin movements driven by this backend (auction bids,
// Razorpay top-ups). The canonical ledger lives on Bet; these rows exist
// purely for backend-side reconciliation + idempotency on payment webhooks.
model CoinTransaction {
  id        String   @id @default(uuid())
  userId    String
  delta     Int      // positive = credit, negative = debit
  reason    String   // "razorpay_purchase" | "bid_cost" | "admin_grant" | "refund"
  reference String?  // razorpay payment_id, bid id, etc — used for idempotency
  metadata  Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@unique([reason, reference], name: "uniq_reason_reference")
}

// Razorpay order — discriminated by `kind`:
//   COIN_PACK    : buys auction coins (coinPackId set, coins > 0)
//   WALLET_TOPUP : tops up the user's INR wallet (coinPackId null, coins 0)
model PaymentOrder {
  id              String   @id @default(uuid())
  userId          String
  kind            PaymentOrderKind @default(COIN_PACK)
  coinPackId      String?
  razorpayOrderId String   @unique
  razorpayPaymentId String?
  amountInr       Decimal  @db.Decimal(10, 2)
  coins           Int      @default(0)
  status          PaymentStatus @default(PENDING)
  createdAt       DateTime @default(now())
  capturedAt      DateTime?

  coinPack        CoinPack? @relation(fields: [coinPackId], references: [id])

  @@index([userId, createdAt])
}

enum PaymentOrderKind {
  COIN_PACK
  WALLET_TOPUP
}

enum PaymentStatus {
  PENDING
  CAPTURED
  FAILED
}

// Short-lived OTP for WhatsApp phone verification. The code is stored as a
// SHA-256 hash; constant-time compared on verify.
model PhoneOtp {
  id        String   @id @default(uuid())
  phone     String
  codeHash  String
  expiresAt DateTime
  consumed  Boolean  @default(false)
  attempts  Int      @default(0)
  // Pending account material — applied when the OTP is verified.
  username  String?
  passwordHash String?
  createdAt DateTime @default(now())

  @@index([phone, createdAt(sort: Desc)])
}

// ─── Aviator (multiplier game) ──────────────────────────────────────────────

model AviatorRound {
  id              String   @id @default(uuid())
  roundNumber     Int      @unique
  // Inline seed copy (also stored on AviatorFairnessSeed). Kept so each round
  // is self-verifiable without joining the seeds table.
  serverSeed      String
  serverSeedHash  String
  clientSeed      String
  // Reference + nonce into the seed batch (added in Slice 2 — null for rounds
  // created before seed rotation existed).
  seedId          String?
  nonce           Int?
  crashMultiplier Decimal  @db.Decimal(10, 2)
  status          AviatorRoundStatus @default(BETTING)
  startedAt       DateTime @default(now())
  crashedAt       DateTime?

  seed AviatorFairnessSeed? @relation(fields: [seedId], references: [id])
  bets AviatorBet[]

  @@index([status])
  @@index([startedAt(sort: Desc)])
  @@index([seedId])
}

enum AviatorRoundStatus {
  BETTING
  RUNNING
  CRASHED
}

/// Batched provably-fair seed. Each row spans many rounds (nonce 1..N).
/// `serverSeed` is private until `revealedAt` is set; `serverSeedHash` is
/// always public. After rotation, users can verify every round that used
/// this seed by recomputing the crash multiplier.
model AviatorFairnessSeed {
  id               String    @id @default(uuid())
  serverSeed       String
  serverSeedHash   String    @unique
  clientSeed       String    // common to the batch
  startedAt        DateTime  @default(now())
  revealedAt       DateTime?
  isActive         Boolean   @default(true)
  rotationReason   String?   // "scheduled" | "admin" | "max_rounds"
  startRoundNumber Int?      // first round
  endRoundNumber   Int?      // last round (set on rotation)

  rounds AviatorRound[]

  @@index([isActive])
}

model AviatorBet {
  id                  String   @id @default(uuid())
  userId              String
  roundId             String
  amount              Int      // demo credits
  autoCashoutAt       Decimal? @db.Decimal(10, 2)
  cashedOutAt         DateTime?
  cashedOutMultiplier Decimal? @db.Decimal(10, 2)
  payout              Int?
  createdAt           DateTime @default(now())

  user  User         @relation(fields: [userId], references: [id])
  round AviatorRound @relation(fields: [roundId], references: [id], onDelete: Cascade)

  @@unique([userId, roundId]) // one bet per user per round
  @@index([roundId])
  @@index([userId, createdAt(sort: Desc)])
}

model AviatorChatMessage {
  id        String   @id @default(uuid())
  userId    String
  message   String   @db.VarChar(280)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([createdAt(sort: Desc)])
}

/// Singleton admin-tunable knobs for Aviator. Exactly one row (id=1).
///
///   - maxPayout: optional global ceiling. When set, every round's
///     computed crashMultiplier is clipped to this value before the
///     round is published. Default null = uncapped. This does NOT
///     change the provably-fair RNG (the round is still verifiable
///     against its seed + nonce + the published cap).
///   - forcedNextPayout: one-shot admin override. Set by the admin to
///     pin the next round's crash multiplier to a specific value. The
///     scheduler consumes (reads + clears) this in a single
///     transaction at the start of each BETTING phase, so it fires
///     exactly once and the auction then reverts to normal behaviour.
model AviatorSettings {
  id               Int      @id @default(1)
  maxPayout        Decimal? @db.Decimal(10, 2)
  forcedNextPayout Decimal? @db.Decimal(10, 2)
  updatedAt        DateTime @updatedAt
}

// ════════════════════════════════════════════════════════════════════
//
//   FOUNDATION — Cross-cutting tables introduced by the production
//   readiness program. See `docs/PRODUCTION_ROADMAP.md` for the design
//   rationale per group. All tables here are additive — no existing
//   model is mutated beyond adding optional fields + back-relations.
//
//   This block is schema-only; the bulk of business logic lands in
//   subsequent feature PRs, each gated behind a FeatureFlag row.
//
// ════════════════════════════════════════════════════════════════════

// ───── RBAC + Admin (Roadmap §1D) ───────────────────────────────────

enum Role {
  ADMIN
  MODERATOR
  FINANCE
  SUPPORT
  AUDITOR
}

model UserRole {
  userId    String
  role      Role
  grantedBy String?
  grantedAt DateTime  @default(now())
  // Soft revoke — kept for audit; missing row vs revokedAt set both deny.
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, role])
  @@index([role, revokedAt])
}

// ───── Admin audit log (Roadmap §1C) ────────────────────────────────

model AdminAuditLog {
  id            String   @id @default(cuid())
  actorId       String
  actorEmail    String                                 // snapshot
  action        String                                 // "auction.update", "withdrawal.approve", etc.
  targetType    String                                 // "Auction", "User", "WithdrawalRequest"
  targetId      String
  before        Json?                                  // sparse — only changed fields
  after         Json?
  ipAddress     String?
  userAgent     String?
  correlationId String?                                // joins request log entries
  createdAt     DateTime @default(now())
  actor         User     @relation("AuditActor", fields: [actorId], references: [id])

  @@index([actorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@index([action, createdAt])
  @@index([correlationId])
}

// ───── Feature flags + Settings (Roadmap §1E, §1F) ──────────────────

enum FlagMode {
  BOOLEAN
  ROLE
  PERCENT
}

model FeatureFlag {
  id             String   @id                          // dotted key: "watchlist.enabled"
  description    String
  mode           FlagMode @default(BOOLEAN)
  enabled        Boolean  @default(false)
  roles          Role[]   @default([])
  rolloutPercent Int      @default(0)
  updatedBy      String?
  updatedAt      DateTime @updatedAt
  createdAt      DateTime @default(now())
}

enum SettingType {
  INT
  FLOAT
  STRING
  BOOL
  JSON
}

model SystemSetting {
  key         String      @id                          // dotted key: "wallet.withdraw_min_coins"
  value       Json
  valueType   SettingType
  description String?
  updatedBy   String?
  updatedAt   DateTime    @updatedAt
  createdAt   DateTime    @default(now())
}

model SystemSettingHistory {
  id        String   @id @default(cuid())
  key       String
  before    Json?
  after     Json?
  changedBy String
  changedAt DateTime @default(now())

  @@index([key, changedAt])
}

// ───── Outbox (Roadmap §1B) ─────────────────────────────────────────

enum OutboxKind {
  BET_WALLET_DEBIT
  BET_WALLET_CREDIT
  FCM_PUSH
  SES_EMAIL
  RAZORPAY_REFUND
  ADMIN_AUDIT_REPLAY
}

enum OutboxStatus {
  PENDING
  IN_FLIGHT
  COMPLETED
  FAILED
  DEAD
}

model Outbox {
  id             String       @id @default(cuid())
  kind           OutboxKind
  sourceTable    String
  sourceId       String
  payload        Json
  idempotencyKey String       @unique
  status         OutboxStatus @default(PENDING)
  attempts       Int          @default(0)
  nextAttemptAt  DateTime     @default(now())
  lastError      String?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())

  @@index([status, nextAttemptAt])
  @@index([sourceTable, sourceId])
}

// ───── Notifications (Roadmap §1A) ──────────────────────────────────

enum NotificationChannel {
  PUSH
  EMAIL
  INAPP
}

enum NotificationStatus {
  PENDING
  RENDERED
  SENT
  DELIVERED
  FAILED
  RETRY
  DEAD
}

// ───── Email suppression list (PR-NOTIFY-2) ─────────────────────────
//
// Populated by the SNS webhook on bounce / complaint. Every email send
// checks this table first — a permanent bounce stays suppressed
// forever; a complaint (spam button) also stays forever to avoid
// repeat-offender domain reputation damage.
//
// Transient bounces (the SNS bounceType=Transient) don't land here —
// we let SES handle the retry semantics inside its own queue. Only
// the Permanent + Complaint signal types make the row.
enum EmailSuppressionReason {
  HARD_BOUNCE
  COMPLAINT
  MANUAL
}

model EmailSuppression {
  email     String                  @id
  reason    EmailSuppressionReason
  // Snapshot of the bounce subtype ("General", "NoEmail", "Suppressed",
  // "OnAccountSuppressionList") or complaint feedback type.
  subtype   String?
  // Raw provider payload kept for forensic / appeal handling.
  metadata  Json?
  createdAt DateTime                @default(now())

  @@index([reason, createdAt])
}

model NotificationTemplate {
  id        String              @id @default(cuid())
  code      String                                     // e.g. "auction_outbid_v1"
  channel   NotificationChannel
  locale    String              @default("en")
  subject   String?
  body      String                                     // Handlebars-style; variables key-restricted
  variables Json                @default("{}")         // { auctionTitle: "string", ... }
  active    Boolean             @default(true)
  version   Int                 @default(1)
  updatedAt DateTime            @updatedAt
  createdAt DateTime            @default(now())

  @@unique([code, channel, locale])
}

model Notification {
  id               String              @id @default(cuid())
  userId           String
  templateCode     String
  channel          NotificationChannel
  status           NotificationStatus  @default(PENDING)
  payload          Json
  rendered         Json?
  deliveryAttempts Int                 @default(0)
  lastAttemptAt    DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  failureReason    String?
  idempotencyKey   String              @unique
  // Audit + analytics link.
  campaignId       String?
  createdAt        DateTime            @default(now())
  user             User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
  @@index([userId, readAt])
  @@index([campaignId])
}

model NotificationPreference {
  userId              String  @id
  outbid              Boolean @default(true)
  auctionEnding       Boolean @default(true)
  orderUpdates        Boolean @default(true)
  dailyStreak         Boolean @default(true)
  marketingPush       Boolean @default(false)
  marketingEmail      Boolean @default(true)
  responsibleGambling Boolean @default(true)           // regulatory — cannot be opted out of
  user                User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ───── Watchlist (Roadmap F-USER-1) ─────────────────────────────────

model Watchlist {
  id             String    @id @default(cuid())
  userId         String
  auctionId      String
  lastNotifiedAt DateTime?
  createdAt      DateTime  @default(now())
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  auction        Auction   @relation(fields: [auctionId], references: [id], onDelete: Cascade)

  @@unique([userId, auctionId])
  @@index([auctionId])
}

// ───── Shipping addresses (Roadmap F-USER-6) ────────────────────────

model ShippingAddress {
  id          String    @id @default(cuid())
  userId      String
  // PII fields — encrypted at rest at the application layer.
  fullName    String
  phoneE164   String
  line1       String
  line2       String?
  city        String
  state       String                                   // ISO 3166-2 region code
  postalCode  String
  countryIso2 String                                   // ISO 3166-1 alpha-2
  isDefault   Boolean   @default(false)
  // Soft delete preserves the snapshot for past Order references.
  deletedAt   DateTime?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders      Order[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId, deletedAt])
}

// ───── Orders (Roadmap F-USER-7) ────────────────────────────────────

enum OrderStatus {
  PENDING_ADDRESS
  AWAITING_FULFILLMENT
  IN_TRANSIT
  DELIVERED
  DISPUTED
  CANCELLED
}

model Order {
  id                      String           @id @default(cuid())
  auctionId               String           @unique
  winnerId                String
  shippingAddressId       String?
  // Immutable snapshot captured at checkout; survives address deletion.
  shippingAddressSnapshot Json?
  status                  OrderStatus      @default(PENDING_ADDRESS)
  fulfillmentNotes        String?
  carrierName             String?
  trackingNumber          String?
  trackingUrl             String?
  shippedAt               DateTime?
  deliveredAt             DateTime?
  deliveredBy             String?
  disputedAt              DateTime?
  disputeReason           String?
  shippingAddress         ShippingAddress? @relation(fields: [shippingAddressId], references: [id])
  // PR-ORDER-1: forward relation to Auction. The Auction model's
  // back-ref is also wired now so prisma includes can join both ways.
  auction                 Auction          @relation("AuctionOrder", fields: [auctionId], references: [id], onDelete: Cascade)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  @@index([winnerId, status])
  @@index([status, updatedAt])
}

// ───── Referrals (Roadmap F-USER-4) ─────────────────────────────────

enum ReferralStatus {
  PENDING
  QUALIFIED
  PAID
  VOIDED
}

model ReferralClaim {
  id                      String         @id @default(cuid())
  referrerId              String
  refereeId               String         @unique                    // one-shot
  code                    String                                     // snapshot
  status                  ReferralStatus @default(PENDING)
  qualifiedAt             DateTime?
  paidAt                  DateTime?
  referrerRewardCoins     Int
  refereeRewardCoins      Int
  // Anti-fraud fingerprints (snapshot at signup).
  refereeSignupIp         String?
  refereeSignupDeviceHash String?
  voidReason              String?
  referrer                User           @relation("ReferralReferrer", fields: [referrerId], references: [id])
  referee                 User           @relation("ReferralReferee", fields: [refereeId], references: [id])
  createdAt               DateTime       @default(now())

  @@index([referrerId, status])
  @@index([code])
}

// ───── KYC (Roadmap F-USER-13) ──────────────────────────────────────

enum KycTier {
  TIER_0
  TIER_1
  TIER_2
  TIER_3
}

enum ReviewState {
  NONE
  PENDING
  APPROVED
  REJECTED
  REQUIRES_RESUBMIT
}

enum DocumentKind {
  PAN
  AADHAAR_LAST4
  PASSPORT
  VOTER_ID
  ADDRESS_PROOF
  SELFIE
  LIVENESS_VIDEO
}

enum ScanStatus {
  PENDING
  CLEAN
  INFECTED
  ERROR
}

model KycVerification {
  id                 String        @id @default(cuid())
  userId             String        @unique
  tier               KycTier       @default(TIER_0)
  emailVerifiedAt    DateTime?
  phoneVerifiedAt    DateTime?
  identityVerifiedAt DateTime?
  addressVerifiedAt  DateTime?
  reviewState        ReviewState   @default(NONE)
  reviewedBy         String?
  reviewedAt         DateTime?
  reviewNotes        String?
  documents          KycDocument[]
  user               User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt          DateTime      @updatedAt
  createdAt          DateTime      @default(now())

  @@index([tier])
  @@index([reviewState, updatedAt])
}

model KycDocument {
  id                   String        @id @default(cuid())
  kycId                String
  kind                 DocumentKind
  fileKey              String                                       // S3 key in encrypted-sensitive bucket
  fileSizeBytes        Int
  mimeType             String
  virusScanStatus      ScanStatus    @default(PENDING)
  ocrText              String?
  reviewState          ReviewState   @default(PENDING)
  reviewerId           String?
  reviewNotes          String?
  encryptionKeyVersion Int           @default(1)
  kyc                  KycVerification @relation(fields: [kycId], references: [id], onDelete: Cascade)
  createdAt            DateTime      @default(now())

  @@index([kycId, kind])
  @@index([reviewState, createdAt])
}

// ───── Responsible Gambling (Roadmap F-USER-14) ─────────────────────

enum RgEventKind {
  DEPOSIT_BLOCKED_BY_LIMIT
  BET_BLOCKED_BY_LIMIT
  LOSS_LIMIT_REACHED
  SESSION_REMINDER_SHOWN
  COOLDOWN_STARTED
  COOLDOWN_ENDED
  SELF_EXCLUSION_STARTED
  SELF_EXCLUSION_ENDED
}

model ResponsibleGamblingProfile {
  userId                   String    @id
  dailyDepositLimitCoins   Int?
  weeklyDepositLimitCoins  Int?
  monthlyDepositLimitCoins Int?
  dailyLossLimitCoins      Int?
  weeklyLossLimitCoins     Int?
  monthlyLossLimitCoins    Int?
  dailyWagerLimitCoins     Int?
  sessionReminderMinutes   Int       @default(30)
  cooldownUntil            DateTime?
  selfExcludedUntil        DateTime?
  selfExcludedAt           DateTime?
  // 24h cool-off for limit RAISES (PR-RG-2). When the user requests a
  // looser limit we don't apply it immediately — we stash the new
  // value in `pendingLimits` and schedule it to take effect at
  // `pendingActivatesAt`. The user can cancel before that moment.
  pendingLimits            Json?
  pendingActivatesAt       DateTime?
  // Session tracking for the periodic reminder feature (PR-RG-2).
  // `sessionStartedAt` resets on first ping after > 30 min idle gap;
  // `lastReminderAt` debounces the "you've been playing X minutes"
  // toast so it doesn't fire on every heartbeat once the threshold
  // has been crossed.
  sessionStartedAt         DateTime?
  lastSessionPingAt        DateTime?
  lastReminderAt           DateTime?
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  updatedAt                DateTime  @updatedAt
  createdAt                DateTime  @default(now())
}

model ResponsibleGamblingEvent {
  id                String     @id @default(cuid())
  userId            String
  kind              RgEventKind
  amount            Int?
  limitKind         String?                                          // "daily_deposit", "weekly_loss"
  limitValue        Int?
  sessionDurationMs Int?
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime   @default(now())

  @@index([userId, createdAt])
  @@index([kind, createdAt])
}

// ───── Support tickets (Roadmap F-USER-15) ──────────────────────────

enum TicketStatus {
  OPEN
  AWAITING_USER
  AWAITING_ADMIN
  ESCALATED
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketCategory {
  ACCOUNT
  WITHDRAWAL
  DEPOSIT
  BIDDING
  AVIATOR
  ORDER_FULFILLMENT
  TECHNICAL
  OTHER
}

enum TicketCloseReason {
  RESOLVED
  DUPLICATE
  INVALID
  NO_RESPONSE
}

model SupportTicket {
  id               String           @id @default(cuid())
  userId           String
  subject          String
  status           TicketStatus     @default(OPEN)
  priority         TicketPriority   @default(NORMAL)
  category         TicketCategory
  slaDueAt         DateTime
  firstResponseAt  DateTime?
  // Free-form back-link to whatever subject the ticket is about
  // (Auction, WithdrawalRequest, AviatorBet, etc.).
  linkedEntityType String?
  linkedEntityId   String?
  assignedToId     String?
  closedAt         DateTime?
  closedReason     TicketCloseReason?
  user             User             @relation(fields: [userId], references: [id])
  assignedTo       User?            @relation("AssignedTickets", fields: [assignedToId], references: [id])
  messages         SupportMessage[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([status, slaDueAt])
  @@index([assignedToId, status])
  @@index([userId, createdAt])
}

model SupportMessage {
  id          String              @id @default(cuid())
  ticketId    String
  senderId    String
  isFromAdmin Boolean
  body        String
  isInternal  Boolean             @default(false)                   // visible to admins only
  attachments SupportAttachment[]
  ticket      SupportTicket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender      User                @relation(fields: [senderId], references: [id])
  createdAt   DateTime            @default(now())

  @@index([ticketId, createdAt])
}

model SupportAttachment {
  id              String         @id @default(cuid())
  messageId       String
  fileKey         String                                            // S3 key
  fileName        String
  fileSizeBytes   Int
  mimeType        String
  virusScanStatus ScanStatus     @default(PENDING)
  message         SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
}

// ───── Reconciliation (Roadmap F-ADMIN-5, PR-RECON-1) ─────────────
//
// Nightly job compares per-user CoinTransaction sums against Bet's
// current wallet balance. Discrepancies surface in the admin queue
// for human follow-up.

enum ReconciliationStatus {
  RUNNING
  COMPLETED
  FAILED
}

model ReconciliationReport {
  id              String                       @id @default(cuid())
  // The UTC day this report covers — unique so we never run twice
  // for the same day. Stored as a midnight timestamp.
  forDate         DateTime                     @unique
  status          ReconciliationStatus         @default(RUNNING)
  startedAt       DateTime                     @default(now())
  completedAt     DateTime?
  failureReason   String?
  // Aggregate metrics for the dashboard summary.
  usersChecked    Int                          @default(0)
  usersOk         Int                          @default(0)
  usersDiscrepant Int                          @default(0)
  totalAbsDrift   Int                          @default(0)
  discrepancies   ReconciliationDiscrepancy[]
  createdAt       DateTime                     @default(now())

  @@index([status, forDate])
}

model ReconciliationDiscrepancy {
  id           String                @id @default(cuid())
  reportId     String
  userId       String
  // Sum of CoinTransaction.delta for this user up to the snapshot
  // moment (signed integer).
  localSum     Int
  // Current balance from Bet's wallet.
  remoteSum    Int
  // localSum - remoteSum. Non-zero means drift.
  drift        Int
  notes        String?
  acknowledged Boolean               @default(false)
  ackedBy      String?
  ackedAt      DateTime?
  report       ReconciliationReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  createdAt    DateTime              @default(now())

  @@index([reportId, drift])
  @@index([userId, createdAt])
}

// ───── Fraud signals (Roadmap F-ADMIN-7, PR-FRAUD-1) ──────────────
//
// Append-only signal log produced by the velocity + cluster
// heuristics. Each row represents a single fired rule — admins
// review them and either ack-without-action or escalate via the
// review queue.

enum FraudSignalKind {
  VELOCITY_BID
  VELOCITY_LOGIN
  VELOCITY_WITHDRAWAL
  CLUSTER_IP
  CLUSTER_DEVICE
  CLUSTER_REFERRAL
}

enum FraudSeverity {
  LOW
  MEDIUM
  HIGH
}

model FraudSignal {
  id              String          @id @default(cuid())
  kind            FraudSignalKind
  severity        FraudSeverity
  // Single-user signal (velocity) → userId set.
  // Cluster signal (IP/device/referral) → userId null, clusterKey set.
  userId          String?
  clusterKey      String?
  // For cluster signals, a list of affected user IDs as JSON array.
  affectedUserIds Json?
  // Free-form metadata for the rule that fired (count, threshold, etc.).
  metadata        Json
  reviewed        Boolean         @default(false)
  reviewedBy      String?
  reviewedAt      DateTime?
  notes           String?
  createdAt       DateTime        @default(now())

  @@index([reviewed, severity, createdAt])
  @@index([userId, createdAt])
  @@index([clusterKey, kind])
}

// ───── Promo codes (Roadmap F-USER-12, PR-CAMPAIGN-1) ─────────────
//
// Discount codes redeemable against coin-pack purchases. Two
// discount kinds (PERCENT 1-100, FLAT in paise). Lifetime + per-user
// caps. Optional CoinPack id allowlist for "first-coin-pack-only"
// or "premium-tier-only" campaigns.

enum PromoCodeDiscountType {
  PERCENT
  FLAT
}

model PromoCode {
  id              String                @id @default(cuid())
  code            String                @unique
  discountType    PromoCodeDiscountType
  // For PERCENT: integer 1-100. For FLAT: paise.
  discountValue   Int
  // Lifetime total uses cap. NULL = unlimited.
  maxUses         Int?
  // Per-user uses cap. Most campaigns set this to 1.
  maxUsesPerUser  Int                   @default(1)
  expiresAt       DateTime?
  // If non-empty, the code is only valid against the listed CoinPack
  // ids. Empty array = applies to any coin pack.
  coinPackIds     String[]              @default([])
  enabled         Boolean               @default(true)
  createdBy       String                                           // admin user id
  notes           String?                                          // admin-only
  redemptions     PromoCodeRedemption[]
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@index([enabled, expiresAt])
}

model PromoCodeRedemption {
  id             String     @id @default(cuid())
  promoCodeId    String
  userId         String
  // PaymentOrder snapshot — kept as a free-form id so we don't need a
  // FK to a table that lives in this same backend (or, future, Bet).
  paymentOrderId String?
  // Discount applied in paise. Mirrors what the payment gateway saw.
  discountInr    Int
  promoCode      PromoCode  @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)
  createdAt      DateTime   @default(now())

  @@index([userId, promoCodeId])
  @@index([promoCodeId, createdAt])
}

// ───── Profile history (Roadmap F-USER-5 audit trail) ───────────────

// PR-PROFILE-2 review states. NONE = automated change with no flag;
// PENDING = profanity/reserved-name borderline match awaiting admin
// eyes; KEPT_AS_IS = admin reviewed + said it's fine; FORCED_RENAME =
// admin renamed the user (handled by an entry in this very table
// where `field = "displayName"` and the admin is the author).
enum ProfileReviewAction {
  NONE
  PENDING
  KEPT_AS_IS
  FORCED_RENAME
}

model UserProfileHistory {
  id           String              @id @default(cuid())
  userId       String
  field        String                                                  // "displayName", "avatarKey"
  before       String?
  after        String?
  changedAt    DateTime            @default(now())
  // PR-PROFILE-2: moderation surface. flagReason is human-readable
  // ("profanity:hindi-roman", "reserved:admin"); reviewAction is the
  // disposition once an admin looks at it.
  flagReason   String?
  reviewAction ProfileReviewAction @default(NONE)
  reviewedAt   DateTime?
  reviewedBy   String?
  reviewNotes  String?
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, changedAt])
  // Cheap lookup for the queue page: "all unreviewed flagged rows,
  // newest first."
  @@index([reviewAction, changedAt])
}

// ───── Auth — password reset, 2FA, email change, account deletion ──

model PasswordReset {
  id          String    @id @default(cuid())
  userId      String
  // Hash of the reset token sent in the email — never store plaintext.
  tokenHash   String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  requestedIp String?
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())

  @@index([userId, usedAt])
}

model TwoFactorAuth {
  userId          String    @id
  // Encrypted TOTP secret (pgp_sym_encrypt w/ KMS key).
  encryptedSecret String
  // Becomes true after the first successful TOTP submission.
  verified        Boolean   @default(false)
  // Each entry is a bcrypt-hashed one-time backup code.
  backupCodes     String[]  @default([])
  enabledAt       DateTime?
  disabledAt      DateTime?
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime  @default(now())
}

model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  // Opaque hash of (UA + accept-language + server-issued nonce).
  deviceHash String
  label      String?
  lastSeenAt DateTime @default(now())
  expiresAt  DateTime                                               // 90d default
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceHash])
  @@index([userId, expiresAt])
}

model EmailChangeRequest {
  id             String    @id @default(cuid())
  userId         String
  oldEmail       String
  newEmail       String
  // Two tokens — one mailed to each address. Both must be clicked.
  oldTokenHash   String    @unique
  newTokenHash   String    @unique
  oldConfirmedAt DateTime?
  newConfirmedAt DateTime?
  expiresAt      DateTime                                            // 24h
  appliedAt      DateTime?
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())

  @@index([userId])
}

model AccountDeletion {
  id           String    @id @default(cuid())
  userId       String    @unique
  reason       String?
  requestedAt  DateTime  @default(now())
  effectiveAt  DateTime                                             // request + 30d
  cancelledAt  DateTime?
  purgedAt     DateTime?
  user         User      @relation(fields: [userId], references: [id])
}

// ───── Exports (Roadmap F-USER-2, F-USER-12) ────────────────────────

enum ExportKind {
  TRADE_HISTORY
  WALLET_LEDGER
  BID_HISTORY
}

enum ExportStatus {
  QUEUED
  RUNNING
  READY
  FAILED
  EXPIRED
}

model UserExport {
  id             String       @id @default(cuid())
  userId         String
  kind           ExportKind
  filters        Json
  status         ExportStatus @default(QUEUED)
  rowCount       Int?
  fileKey        String?
  fileSizeBytes  Int?
  expiresAt      DateTime
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model DataExportRequest {
  id         String       @id @default(cuid())
  userId     String
  fileKey    String?
  expiresAt  DateTime
  status     ExportStatus @default(QUEUED)
  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())

  @@index([userId, status])
}

// ───── Daily login / streak (Roadmap F-USER-8) ──────────────────────

model DailyLogin {
  userId         String    @id
  streak         Int       @default(0)
  lastClaimAt    DateTime?
  streakFreezes  Int       @default(0)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model DailyLoginClaim {
  id           String   @id @default(cuid())
  userId       String
  dayNumber    Int
  rewardCoins  Int
  // Truncated to UTC midnight — uniq per (user, date) prevents double-claim.
  claimDateUtc DateTime @db.Date
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@unique([userId, claimDateUtc])
  @@index([userId, claimDateUtc])
}

// ───── Admin impersonation log (Roadmap F-ADMIN-2) ──────────────────

model ImpersonationLog {
  id        String    @id @default(cuid())
  adminId   String
  userId    String
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  reason    String                                                  // required, free-text
  // Each entry: { action, target, at } — actions taken during impersonation.
  actions   Json      @default("[]")
  admin     User      @relation("ImpersonatorAdmin", fields: [adminId], references: [id])
  user      User      @relation("ImpersonatedUser", fields: [userId], references: [id])

  @@index([adminId, startedAt])
  @@index([userId, startedAt])
}
