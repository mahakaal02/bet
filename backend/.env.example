NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://uniquebid:uniquebid@localhost:5432/uniquebid?schema=public

REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

BCRYPT_ROUNDS=10

# Path to a Firebase service-account JSON. Leave unset to no-op (notifications
# are logged instead of delivered). See backend/README.md for setup.
# FIREBASE_CREDENTIALS_PATH=/absolute/path/to/serviceAccount.json

# Razorpay credentials. Get test keys at https://dashboard.razorpay.com/.
# When unset, payment endpoints respond 503.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
