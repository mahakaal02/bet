NODE_ENV=development
PORT=4000

DATABASE_URL=postgresql://uniquebid:uniquebid@localhost:5432/uniquebid?schema=public

REDIS_URL=redis://localhost:6379

JWT_SECRET=replace-me-with-a-long-random-string
JWT_EXPIRES_IN=7d

BCRYPT_ROUNDS=10

# Path to a Firebase service-account JSON. Leave unset to no-op (notifications
# are logged instead of delivered). See backend/README.md for setup.
# FIREBASE_CREDENTIALS_PATH=/absolute/path/to/serviceAccount.json

# Razorpay credentials. Get test keys at https://dashboard.razorpay.com/.
# When unset, payment endpoints respond 503.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ────────────────────────────────────────────────────────────────────
# Aviator crash-distribution engine (configurable heavy-tail multiplier)
# ────────────────────────────────────────────────────────────────────
# Every key here is also mirrored in the `SystemSetting` catalog
# (migration 20260524000000_crash_engine_settings). DB row wins;
# falling back to the env var means dev boxes can experiment with the
# engine without inserting a SystemSetting row first.
#
# Disabled by default — flip `AVIATOR_CRASH_ENGINE` to `heavytail` to
# enable. Existing seed audits keep working byte-for-byte under
# `legacy`.
#
# AVIATOR_CRASH_ENGINE=heavytail            # legacy | heavytail
# AVIATOR_CRASH_RTP=0.96                    # Target RTP (1 - house edge)
# AVIATOR_CRASH_MODE=balanced               # balanced | fast_loss | streamer
# AVIATOR_CRASH_ADAPTIVE_ENABLED=true       # EMA-driven mode blending
# AVIATOR_CRASH_ALPHA=0.2                   # EMA decay (0, 1]
# AVIATOR_CRASH_BLEND_STRENGTH=0.2          # Exposure-factor magnitude
# AVIATOR_CRASH_REFERENCE_STAKE=5000        # Reference per-round stake (coins)
